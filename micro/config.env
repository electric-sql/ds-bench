# micro/config.env — the benchmark matrix. Sourced by run.sh.
# Override any of these inline:  DUR=5 REPEATS=1 STUDIES=engines bash run.sh
# A tiny smoke profile is provided by run.sh via PROFILE=smoke.

# Container-friendly binary and data paths (no systemd, no /tmp build dir).
BIN="${BIN:-/usr/local/bin/durable-streams-server}"
DATA="${DATA:-/data}"

# Which studies to run (space-separated). See studies/.
STUDIES="${STUDIES:-engines cpu_scaling memory_cold splice tiering}"

# Core split on an 8-core node (n2d-standard-8, cores 0-7): server gets 0-5,
# client (wrk) gets 6-7, and core 7 is also RESERVED for the system so the bench
# can never lock the box out (this, plus the capped scope below, is the crash-prevention).
SERVER_CPUS="${SERVER_CPUS:-0-5}"
CLIENT_CPUS="${CLIENT_CPUS:-6-7}"

# --- reliability / safety (so a runaway bench can't take down the box) ---
# The orchestrator (and the curl/cargo/wrk it spawns) is pinned with `taskset` to
# BENCH_ALLOWED_CPUS, which OMITS the last core so the system stays schedulable.
# The per-cell SERVER is launched as a taskset background process (no systemd).
#   BENCH_SCOPE=1       pin+nice the orchestrator (set 0 to run unpinned, e.g. macOS)
#   BENCH_ALLOWED_CPUS  cpuset for the orchestrator/curl/cargo (omit the last core)
#   BENCH_MAX_SECONDS   watchdog: hard-stop the run after this long
BENCH_SCOPE="${BENCH_SCOPE:-1}"
BENCH_ALLOWED_CPUS="${BENCH_ALLOWED_CPUS:-0-6}"
BENCH_MAX_SECONDS="${BENCH_MAX_SECONDS:-14400}"   # 4h

# Measurement.
DUR="${DUR:-12}"
REPEATS="${REPEATS:-3}"

# --- engines study ---
MODES="${MODES:-inline tail always}"        # raw --read-offload (raw only)
READ_SIZES="${READ_SIZES:-1024 16384 1048576}"
CONNS_SWEEP="${CONNS_SWEEP:-16 64 256 1024}" # concurrency curve (at SWEEP_SIZE)
SWEEP_SIZE="${SWEEP_SIZE:-1024}"
SIZE_CONN="${SIZE_CONN:-256}"                # conn used for the size sweep
APPEND_MSG="${APPEND_MSG:-100}"

# --- cpu_scaling study --- server cpuset sweep (client stays on CLIENT_CPUS)
SCALE_CPUSETS="${SCALE_CPUSETS:-0-1 0-3 0-5 0-7}"

# --- memory_cold study --- bound the server's page cache to force disk I/O.
COLD_STREAM_GIB="${COLD_STREAM_GIB:-4}"      # cold stream size (> mem caps)
COLD_MEMS="${COLD_MEMS:-infinity 2G 1G 512M}"

# --- splice study ---
SPLICE_SIZES="${SPLICE_SIZES:-65536 1048576}"

# --- tiering study --- local always; s3(MinIO) only if TIER_S3=1.
TIER_SEG_BYTES="${TIER_SEG_BYTES:-1048576}"
TIER_S3="${TIER_S3:-0}"
