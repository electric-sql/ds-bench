{
  "suite": "run-durable",
  "cluster": {
    "server_machine": "c4d-standard-16-lssd",
    "client_machine": "n2d-standard-32",
    "client_nodes": 8,
    "region": "europe-west4"
  },
  "saturation": {
    "plateau_pct": 8,
    "fleet_cpu": 0.5,
    "repeats": 1,
    "warmup_secs": 8,
    "measure_secs": 8,
    "setup_concurrency": 16,
    "payload_bytes": 256
  },
  "modes": ["wal"],
  "server_configs": {
    "wal": [
      { "label": "wal", "args": "" },
      { "label": "wal-tailcache", "args": "--tail-cache-bytes 65536" },
      { "label": "memory", "args": "--durability memory" }
    ]
  },
  "stream_counts": [100, 1000, 10000, 100000],
  "pod_ladder": {
    "100": [16, 24, 32],
    "1000": [16, 24, 32],
    "10000": [32, 48, 64],
    "100000": [80, 100, 110]
  }
}
