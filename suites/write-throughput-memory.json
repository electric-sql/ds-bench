{
  "suite": "write-throughput-memory",
  "cluster": {
    "server_machine": "c4d-standard-16-lssd",
    "client_machine": "n2d-standard-32",
    "client_nodes": 14,
    "region": "europe-west4",
    "cluster_name": "bench-memory",
    "zone": "europe-west4-a"
  },
  "saturation": {
    "plateau_pct": 5,
    "fleet_cpu": 0.5,
    "repeats": 3,
    "warmup_secs": 15,
    "measure_secs": 20,
    "setup_concurrency": 16,
    "payload_bytes": 256
  },
  "modes": [
    "wal"
  ],
  "stream_counts": [
    100,
    1000,
    10000,
    100000
  ],
  "pod_ladder": {
    "100": [
      4,
      8,
      16,
      24,
      32
    ],
    "1000": [
      8,
      16,
      32,
      48,
      64
    ],
    "10000": [
      32,
      64,
      96,
      128,
      160
    ],
    "100000": [
      120,
      160,
      200,
      240
    ]
  },
  "server_configs": {
    "wal": [
      {
        "label": "memory",
        "args": "--durability memory"
      }
    ]
  }
}
